<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.assessx.assessx.controller.CompleteRegistrationController"
           styleClass="login-root">

    <VBox styleClass="login-card"
          maxWidth="480" minWidth="400"
          alignment="CENTER"
          StackPane.alignment="CENTER">
        <padding>
            <Insets bottom="48" left="56" right="56" top="48"/>
        </padding>

        <Label text="AssessX" styleClass="login-brand"/>
        <Label text="Налаштування профілю" styleClass="login-title"/>
        <Label text="Вкажіть ваші дані для завершення реєстрації"
               styleClass="login-subtitle"/>

        <VBox spacing="16" style="-fx-padding: 24 0 0 0;">

            <!-- Name -->
            <VBox spacing="6">
                <Label text="Прізвище та Ім'я" styleClass="field-label"/>
                <TextField fx:id="nameField" promptText="Ваше прізвище та ім'я" styleClass="input-field"/>
                <Label fx:id="nameError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

            <!-- Role -->
            <VBox spacing="8">
                <Label text="Роль" styleClass="field-label"/>
                <HBox spacing="16" styleClass="role-toggle-box">
                    <fx:define>
                        <ToggleGroup fx:id="roleToggleGroup"/>
                    </fx:define>
                    <RadioButton fx:id="studentRadio"
                                 text="Студент"
                                 toggleGroup="$roleToggleGroup"
                                 styleClass="role-radio"/>
                    <RadioButton fx:id="teacherRadio"
                                 text="Викладач"
                                 toggleGroup="$roleToggleGroup"
                                 styleClass="role-radio"/>
                </HBox>
            </VBox>

            <!-- Group (students only) -->
            <VBox fx:id="groupBox" spacing="6">
                <Label text="Номер групи" styleClass="field-label"/>
                <TextField fx:id="groupField"
                           promptText="Наприклад: 123"
                           styleClass="input-field"/>
                <Label fx:id="groupError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

            <!-- Error -->
            <Label fx:id="errorLabel" styleClass="field-error" visible="false" managed="false"
                   wrapText="true"/>

        </VBox>

        <VBox spacing="12" style="-fx-padding: 28 0 0 0;">
            <Button fx:id="submitButton"
                    text="Продовжити"
                    onAction="#onSubmit"
                    styleClass="btn-register"
                    maxWidth="Infinity"/>

            <StackPane alignment="CENTER" minHeight="28">
                <ProgressIndicator fx:id="spinner" maxWidth="28" maxHeight="28"
                                   visible="false" managed="false"/>
            </StackPane>
        </VBox>

    </VBox>
</StackPane>
