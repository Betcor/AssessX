<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.assessx.assessx.controller.DashboardController"
            styleClass="app-root">

    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" spacing="2">
            <Label text="AssessX" styleClass="sidebar-brand"/>
            <Label fx:id="userLabel" text="" styleClass="sidebar-user"/>

            <Pane styleClass="sidebar-separator"/>

            <Label text="НАВІГАЦІЯ" styleClass="sidebar-section"/>

            <Button fx:id="btnDashboard"
                    text="🏠  Головна"
                    onAction="#showDashboard"
                    styleClass="nav-btn,active"
                    maxWidth="Infinity"/>

            <Button fx:id="btnAssignments"
                    text="📋  Завдання"
                    onAction="#showAssignments"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnTests"
                    text="󰭴    Тести"
                    onAction="#showTests"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnPractices"
                    text="💻  Практика"
                    onAction="#showPractices"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnResults"
                    text="📊  Результати"
                    onAction="#showResults"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <!-- Teacher-only section -->
            <VBox fx:id="teacherSection" visible="false" managed="false" spacing="2">
                <Pane styleClass="sidebar-separator"/>
                <Label text="ВИКЛАДАЧ" styleClass="sidebar-section"/>
                <Button fx:id="btnGroups"
                        text="    Групи"
                        onAction="#showGroups"
                        styleClass="nav-btn"
                        maxWidth="Infinity"/>
                <Button fx:id="btnAllResults"
                        text="📈  Всі результати"
                        onAction="#showAllResults"
                        styleClass="nav-btn"
                        maxWidth="Infinity"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <Pane styleClass="sidebar-separator"/>
            <Button text="🚪  Вийти"
                    onAction="#onLogout"
                    styleClass="nav-btn"
                    maxWidth="Infinity"
                    style="-fx-padding: 9 16 16 16;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area">
            <!-- Content is loaded dynamically -->
            <Label fx:id="placeholderLabel"
                   text="Завантаження..."
                   style="-fx-text-fill: #8b949e; -fx-font-size: 16px;"/>
        </StackPane>
    </center>

</BorderPane>
